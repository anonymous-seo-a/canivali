{
  "name": "cannibalization-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "ui:dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create": "tsx src/cli/seed.ts --create",
    "db:migrate": "tsx src/cli/seed.ts --migrate",
    "db:seed": "tsx src/cli/seed.ts --seed-all",
    "db:reset": "tsx src/cli/seed.ts --reset",
    "crawl:soico": "tsx src/cli/crawl-soico.ts",
    "classify:titles": "tsx src/cli/classify-titles.ts",
    "embed:articles": "tsx src/embedding/generate-article-embeddings.ts",
    "embed:north-star": "tsx src/embedding/business-relevance.ts",
    "embed:reclassify-pending": "tsx src/embedding/reclassify-pending.ts",
    "embed:centroids": "tsx src/embedding/topic-centroids.ts",
    "embed:pairs": "tsx src/embedding/pair-similarity.ts",
    "pull:gsc": "tsx src/ingestion/gsc-pull.ts",
    "pull:serp-overlap": "tsx src/ingestion/serp-overlap.ts",
    "verify:env": "tsx scripts/verify-env.ts",
    "verify:db": "tsx scripts/verify-db.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google-analytics/data": "^4.12.0",
    "better-sqlite3": "^11.5.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "googleapis": "^144.0.0",
    "openai": "^4.70.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.48.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
